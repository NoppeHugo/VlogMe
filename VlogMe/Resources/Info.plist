<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>VlogMe</string>
	<key>CFBundleName</key>
	<string>VlogMe</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>

	<!-- Analytics PostHog — renseigne ta clé projet (laisse vide pour désactiver). -->
	<key>POSTHOG_API_KEY</key>
	<string></string>
	<key>POSTHOG_HOST</key>
	<string>https://eu.i.posthog.com</string>

	<!-- Permissions (cf. §6.4) — textes clairs, lus par la review Apple. -->
	<key>NSCameraUsageDescription</key>
	<string>VlogMe utilise la caméra pour filmer tes vlogs.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>VlogMe enregistre le son de tes vlogs.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Pour enregistrer ta vidéo finale dans ta pellicule.</string>
	<key>NSAppleMusicUsageDescription</key>
	<string>VlogMe accède à ta bibliothèque musicale pour ajouter une musique de fond à ton vlog.</string>

	<!-- App principalement portrait (vertical 9:16 par défaut). -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>

	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>vlogme</string>
			</array>
			<key>CFBundleURLName</key>
			<string>pro.vlogme.app</string>
		</dict>
	</array>

	<!-- Schémas externes interrogés via canOpenURL (partage direct). -->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>instagram</string>
		<string>instagram-reels</string>
		<string>instagram-stories</string>
		<string>tiktok</string>
		<string>snapchat</string>
	</array>

	<!-- Écran de lancement : fond blanc (le branding animé est dessiné en SwiftUI). -->
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>LaunchBackground</string>
	</dict>
</dict>
</plist>
